# ── Credenciais e código de referência (NUNCA versionar) ─────────────────────
.env
backend/

# ── Documentação interna de deploy (contém nomes de containers da VPS) ───────
# Arquivos em `deploy/` genéricos (Dockerfile, compose, nginx, swap) VÃO para o
# repo; o passo-a-passo específico da infraestrutura fica fora.
deploy/DEPLOY.md

# ── Simulador ────────────────────────────────────────────────────────────────
simulador/reports/*.json
simulador/reports/*.md
simulador/logs/*.log
simulador/logs/*.log.*

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Ambientes virtuais ────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Testes e cobertura ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
*.log

# ── Logs da aplicação ─────────────────────────────────────────────────────────
logs/

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Dados sensíveis ───────────────────────────────────────────────────────────
# leads.csv é gerado em runtime quando auth falha (ver ADR-008)
data/leads.csv

# ── Bancos SQLite gerados em runtime (staging + observabilidade + lições) ────
# NUNCA versionar: podem ter PII de testes, decisões do curador, etc.
*.db
*.db-journal
*.db-wal
*.db-shm
banco_agil.db
data/*.db

# ── Chaves e segredos (segurança) ─────────────────────────────────────────────
*.pem
*.key
*.pfx
*.crt
id_rsa
id_ed25519

# ── Backups e temporários ─────────────────────────────────────────────────────
*.bak
*.tmp
*.orig
*.rej

# ── Frontend ──────────────────────────────────────────────────────────────────
# O frontend/  tem seu próprio .gitignore — aqui só reforçamos o essencial
frontend/node_modules/
frontend/.env
frontend/dist/
frontend/.vite/
frontend/*.tsbuildinfo
