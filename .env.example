# ── LLM (chat principal) ─────────────────────────────────────────────────────
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_aqui
GEMINI_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.3

# ── Redis (checkpointing de sessão via LangGraph) ────────────────────────────
# Opção 1 — local dev: docker run -d --name redis -p 6379:6379 redis:alpine
# Opção 2 — VPS via tunnel SSH: -L 6379:127.0.0.1:6379
# Opção 3 — VPS Docker: use o nome do container existente (ex.: consciencia-coletiva-redis-1)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_SECONDS=1800

# ── Qdrant (memória de padrões aprendidos — ver ADR-023) ─────────────────────
# Opção 1 — local dev: docker run -d --name qdrant -p 6333:6333 qdrant/qdrant
# Opção 2 — VPS via tunnel SSH: -L 6333:127.0.0.1:6333
# Opção 3 — VPS Docker: http://<nome-do-container>:6333
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_EMBEDDING_DIMENSION=3072
# Máx. requisições simultâneas no Qdrant (semáforo do vector_store async)
QDRANT_MAX_CONCURRENT=4
# Score mínimo para considerar um exemplo relevante na busca semântica (0..1)
QDRANT_SCORE_THRESHOLD=0.5

# ── Embeddings (chave dedicada para não consumir cota do chat) ───────────────
# Pode ser a mesma GEMINI_API_KEY se não tiver chave separada
GEMINI_API_KEY_EMBEDDINGS=sua_chave_aqui
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# ── Worker Curador (chave dedicada; fallback = GEMINI_API_KEY) ───────────────
# Usado por src/worker/curator.py e src/worker/judge.py.
# Deixar igual à GEMINI_API_KEY é OK; separar evita competir cota com o chat.
GEMINI_API_KEY_CURATOR=sua_chave_aqui

# ── Persistência relacional (staging / observabilidade / judge) ──────────────
# Em dev/demo usamos SQLite local (arquivo banco_agil.db na raiz) — zero setup.
# Estas variáveis só são lidas quando migrarmos para asyncpg/Postgres em prod.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=banco_agil
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ── Tavily (cotação de câmbio em tempo real) ─────────────────────────────────
# Obtenha em: https://app.tavily.com
TAVILY_API_KEY=sua_chave_aqui
